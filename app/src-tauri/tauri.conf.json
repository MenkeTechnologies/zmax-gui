{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zemacs-gui",
  "version": "0.1.0",
  "identifier": "com.menketechnologies.zemacs-gui",
  "build": {
    "frontendDist": "../../frontend",
    "beforeDevCommand": "node scripts/copy-embed-terminal.mjs",
    "beforeBuildCommand": "node scripts/copy-embed-terminal.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "zemacs",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
