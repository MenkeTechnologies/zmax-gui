{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zemacs-gui",
  "version": "0.2.9",
  "identifier": "com.menketechnologies.zemacs-gui",
  "build": {
    "frontendDist": "../../frontend",
    "beforeDevCommand": "node scripts/copy-zgui-core.mjs && node scripts/copy-webui.mjs && node scripts/copy-embed-terminal.mjs && node scripts/copy-i18n.mjs && node scripts/copy-file-browser.mjs && node scripts/copy-hooks-editor.mjs && node scripts/prepare-stryke-sidecar.mjs && node scripts/prepare-zemacs-sidecar.mjs",
    "beforeBuildCommand": "node scripts/copy-zgui-core.mjs && node scripts/copy-webui.mjs && node scripts/copy-embed-terminal.mjs && node scripts/copy-i18n.mjs && node scripts/copy-file-browser.mjs && node scripts/copy-hooks-editor.mjs && node scripts/prepare-stryke-sidecar.mjs && node scripts/prepare-zemacs-sidecar.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "zemacs",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost",
      "dangerousDisableAssetCspModification": [
        "style-src"
      ]
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "mvim",
          "zemacs"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/stryke",
      "binaries/zemacs"
    ],
    "fileAssociations": [
      {
        "name": "Text File",
        "role": "Editor",
        "ext": [
          "txt",
          "md",
          "markdown",
          "rst",
          "org",
          "log",
          "csv",
          "tsv",
          "rs",
          "go",
          "c",
          "h",
          "cc",
          "cpp",
          "hpp",
          "java",
          "kt",
          "swift",
          "js",
          "mjs",
          "cjs",
          "ts",
          "tsx",
          "jsx",
          "vue",
          "svelte",
          "py",
          "rb",
          "pl",
          "pm",
          "php",
          "lua",
          "tcl",
          "r",
          "jl",
          "sh",
          "bash",
          "zsh",
          "fish",
          "ps1",
          "bat",
          "html",
          "htm",
          "css",
          "scss",
          "sass",
          "less",
          "json",
          "json5",
          "yaml",
          "yml",
          "toml",
          "ini",
          "conf",
          "cfg",
          "env",
          "xml",
          "svg",
          "sql",
          "graphql",
          "proto",
          "vim",
          "el",
          "lisp",
          "clj",
          "scala",
          "hs",
          "ml",
          "ex",
          "exs",
          "dockerfile",
          "makefile",
          "cmake",
          "gradle"
        ]
      }
    ]
  }
}
