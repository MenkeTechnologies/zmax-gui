{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the zemacs-gui window. The embedded terminal + MacVim GUI commands are app-local Tauri commands; deep-link is needed for the mvim:// URL scheme.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:menu:default",
    "deep-link:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPLOG" }, { "path": "$APPLOG/**" },
        { "path": "$APPDATA" }, { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA" }, { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG" }, { "path": "$APPCONFIG/**" }
      ]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        { "path": "$APPLOG" }, { "path": "$APPLOG/**" },
        { "path": "$APPDATA" }, { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA" }, { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG" }, { "path": "$APPCONFIG/**" }
      ]
    }
  ]
}
